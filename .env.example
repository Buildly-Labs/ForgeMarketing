# ============================================================
# First City Foundry — ForgeMarketing Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# NEVER commit .env to git — it's in .gitignore
# ============================================================

# ── Email (Brevo SMTP) ──────────────────────────────────────
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_SMTP_LOGIN=your-smtp-login@smtp-brevo.com
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
FROM_EMAIL=hello@firstcityfoundry.com
FROM_NAME=First City Foundry
REPLY_TO_EMAIL=hello@firstcityfoundry.com
DEFAULT_FROM_EMAIL=ProducerForge <hello@firstcityfoundry.com>
DAILY_NOTIFICATION_EMAIL=
DAILY_CC_EMAIL=

# ── OpenAI (AI content generation) ──────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ── AI Service (Ollama — local fallback) ────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# ── Database (optional — defaults to SQLite) ────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/forgemarketing
# DATABASE_URL=mysql://user:password@localhost:3306/forgemarketing

# ── Social Media ─────────────────────────────────────────────
# Twitter / X (OAuth 1.0a — from developer.twitter.com)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn (OAuth 2.0 — from linkedin.com/developers)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# Mastodon
MASTODON_BUILDLY_INSTANCE=https://mastodon.social
MASTODON_BUILDLY_TOKEN=
MASTODON_CLOUDNATIVE_INSTANCE=https://mastodon.social
MASTODON_CLOUDNATIVE_TOKEN=
MASTODON_OPENBUILD_INSTANCE=https://mastodon.social
MASTODON_OPENBUILD_TOKEN=

# Bluesky
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── Google Analytics ─────────────────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_ANALYTICS_CREDENTIALS_FILE=
GOOGLE_ANALYTICS_API_KEY=

# ── YouTube ──────────────────────────────────────────────────
YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=

# ── Search APIs (optional, for contact discovery) ────────────
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
BING_API_KEY=

# ── SendGrid (alternative email provider) ────────────────────
SENDGRID_API_KEY=

# ── Rate Limits ──────────────────────────────────────────────
MAX_DAILY_OUTREACH=50
MAX_PER_ORGANIZATION=4
MIN_DELAY_SECONDS=30
MAX_DELAY_SECONDS=60

# ── Site ─────────────────────────────────────────────────────
WEBSITE_URL=https://www.firstcityfoundry.com
SITE_NAME=First City Foundry

# ── Notifications ────────────────────────────────────────────
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# ── Flask App ────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=development

# ── Admin Seed User ──────────────────────────────────────────
ADMIN_EMAIL=admin@firstcityfoundry.com
ADMIN_PASSWORD=changeme

# ── Gateway / Docker ─────────────────────────────────────────
GATEWAY_PORT=80
MARKETING_URL=http://localhost/marketing
PRODUCER_URL=http://localhost/producer

# ── DigitalOcean Spaces (media storage for Producer) ───────────
# Get keys from: DigitalOcean → API → Spaces Access Keys
AWS_ACCESS_KEY_ID=DOxxYOURKEYHERExx
SPACES_SECRET=your_spaces_secret_key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
AWS_S3_CUSTOM_DOMAIN=your-bucket-name.nyc3.digitaloceanspaces.com
AWS_REGION=nyc3

# ── Producer (Django) Database ───────────────────────────────
DATABASE_ENGINE=postgresql
DATABASE_NAME=logic_service
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_HOST=db
DATABASE_PORT=5432
